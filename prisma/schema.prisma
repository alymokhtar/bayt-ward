generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  INSTAPAY
  WALLET
  MIXED
}

enum SaleStatus {
  COMPLETED
  PENDING
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  DAMAGE
  TRANSFER
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARIES
  MARKETING
  SUPPLIES
  MAINTENANCE
  OTHER
}

enum EmployeeAdjustmentType {
  ADVANCE
  DEDUCTION
  ABSENCE
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      UserRole @default(CASHIER)
  salary    Float    @default(0)
  startDate DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales                Sale[]
  purchases            Purchase[]
  returns              Return[]
  stockMovements       StockMovement[]
  expenses             Expense[]            @relation("RecordedExpenses")
  salaryExpenses       Expense[]            @relation("SalaryExpenses")
  employeeAdjustments  EmployeeAdjustment[] @relation("EmployeeAdjustments")
  adjustmentsCreated   EmployeeAdjustment[] @relation("AdjustmentsCreated")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  nameAr      String?
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  description String?
  brand       String?
  categoryId  String
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]

  @@index([categoryId])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  sku           String   @unique
  barcode       String?  @unique
  size          String
  color         String
  colorHex      String?
  costPrice     Float
  sellingPrice  Float
  stockQuantity Int      @default(0)
  minStockLevel Int      @default(5)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  returnItems    ReturnItem[]
  stockMovements StockMovement[]

  @@index([productId])
  @@index([isActive, stockQuantity])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  address   String?
  notes     String?
  totalSpent Float   @default(0)
  visitCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales   Sale[]
  returns Return[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]
}

model Sale {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  customerId     String?
  userId         String
  subtotal       Float
  discountAmount Float         @default(0)
  discountPercent Float        @default(0)
  taxAmount      Float         @default(0)
  totalAmount    Float
  paidAmount     Float
  changeAmount   Float         @default(0)
  paymentMethod  PaymentMethod @default(CASH)
  status         SaleStatus    @default(COMPLETED)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer Customer?  @relation(fields: [customerId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  items    SaleItem[]
  returns  Return[]

  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model SaleItem {
  id               String @id @default(cuid())
  saleId           String
  variantId        String
  quantity         Int
  unitPrice        Float
  discountAmount   Float  @default(0)
  totalPrice       Float

  sale    Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@index([variantId])
}

model Purchase {
  id            String         @id @default(cuid())
  invoiceNumber String         @unique
  supplierId    String
  userId        String
  subtotal      Float
  taxAmount     Float          @default(0)
  totalAmount   Float
  status        PurchaseStatus @default(PENDING)
  notes         String?
  receivedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  user     User           @relation(fields: [userId], references: [id])
  items    PurchaseItem[]

  @@index([supplierId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model PurchaseItem {
  id         String @id @default(cuid())
  purchaseId String
  variantId  String
  quantity   Int
  unitCost   Float
  totalCost  Float

  purchase Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@index([variantId])
}

model Return {
  id            String         @id @default(cuid())
  returnNumber  String         @unique
  saleId        String
  customerId    String?
  userId        String
  totalAmount   Float
  refundAmount  Float
  refundMethod  PaymentMethod?
  reason        String?
  status        ReturnStatus   @default(APPROVED)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  sale     Sale         @relation(fields: [saleId], references: [id])
  customer Customer?    @relation(fields: [customerId], references: [id])
  user     User         @relation(fields: [userId], references: [id])
  items    ReturnItem[]

  @@index([saleId])
  @@index([customerId])
  @@index([userId])
  @@index([createdAt])
}

model ReturnItem {
  id         String @id @default(cuid())
  returnId   String
  variantId  String
  quantity   Int
  unitPrice  Float
  totalPrice Float

  return  Return         @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([returnId])
  @@index([variantId])
}

model StockMovement {
  id          String            @id @default(cuid())
  variantId   String
  userId      String
  type        StockMovementType
  quantity    Int
  previousQty Int
  newQty      Int
  reference   String?
  notes       String?
  createdAt   DateTime          @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id])
  user    User           @relation(fields: [userId], references: [id])

  @@index([variantId])
  @@index([userId])
  @@index([createdAt])
  @@index([variantId, createdAt])
}

model Expense {
  id              String          @id @default(cuid())
  title           String
  amount          Float
  category        ExpenseCategory @default(OTHER)
  description     String?
  userId          String
  employeeId      String?
  baseSalary      Float?
  deductionsTotal Float?
  expenseDate     DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user        User                 @relation("RecordedExpenses", fields: [userId], references: [id])
  employee    User?                @relation("SalaryExpenses", fields: [employeeId], references: [id])
  adjustments EmployeeAdjustment[]

  @@index([userId])
  @@index([employeeId])
  @@index([expenseDate])
}

model EmployeeAdjustment {
  id             String                 @id @default(cuid())
  userId         String
  createdById    String
  type           EmployeeAdjustmentType
  amount         Float
  title          String?
  notes          String?
  adjustmentDate DateTime               @default(now())
  settled        Boolean                @default(false)
  settledAt      DateTime?
  expenseId      String?
  createdAt      DateTime               @default(now())

  employee  User     @relation("EmployeeAdjustments", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User     @relation("AdjustmentsCreated", fields: [createdById], references: [id])
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@index([userId, settled])
  @@index([expenseId])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
