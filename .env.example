# Neon pooler URL — required for Vercel/serverless
# Use the "-pooler" hostname from Neon dashboard
# Add pgbouncer=true for Prisma on serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DATABASE?sslmode=require&pgbouncer=true"

JWT_SECRET="change-this-to-a-random-secret"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
